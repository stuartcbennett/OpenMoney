<UserControl x:Class="OpenMoney.App.Views.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:core="clr-namespace:OpenMoney.Core.Models;assembly=OpenMoney.Core"
             Loaded="UserControl_Loaded">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Account list -->
        <DockPanel Grid.Column="0" Margin="0 0 12 0">
            <TextBlock DockPanel.Dock="Top" Text="Accounts" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0 0 0 8"/>
            <ListBox ItemsSource="{Binding Accounts}"
                     SelectedItem="{Binding SelectedAccount}"
                     DisplayMemberPath="Name"/>
        </DockPanel>

        <!-- Transaction list -->
        <DockPanel Grid.Column="1" Margin="0 0 12 0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 8">
                <TextBlock Text="Transactions" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" VerticalAlignment="Center"/>
                <Button Content="Add" Command="{Binding StartAddCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="12 0 4 0"/>
                <Button Content="Edit" Command="{Binding StartEditCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="4 0"/>
                <Button Content="Delete" Command="{Binding DeleteCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="4 0"/>
            </StackPanel>
            <DataGrid ItemsSource="{Binding Transactions}"
                      SelectedItem="{Binding SelectedTransaction}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date"       Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="100"/>
                    <DataGridTextColumn Header="Investment"  Binding="{Binding Investment.Name}"              Width="*"/>
                    <DataGridTextColumn Header="Activity"    Binding="{Binding Activity}"                     Width="130"/>
                    <DataGridTextColumn Header="Quantity"    Binding="{Binding Quantity, StringFormat=N3}"    Width="80"/>
                    <DataGridTextColumn Header="Price"       Binding="{Binding Price, StringFormat=C}"        Width="80"/>
                    <DataGridTextColumn Header="Total"       Binding="{Binding Total, StringFormat=C}"        Width="90"/>
                    <DataGridTextColumn Header="Memo"        Binding="{Binding Memo}"                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Edit form -->
        <Border Grid.Column="2"
                Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
                Padding="12" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="Transaction" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0 0 0 12"/>

                <DatePicker materialDesign:HintAssist.Hint="Date"
                            SelectedDate="{Binding EditDate}"
                            Style="{StaticResource MaterialDesignDatePicker}" Margin="0 0 0 8"/>

                <ComboBox materialDesign:HintAssist.Hint="Investment"
                          ItemsSource="{Binding Investments}"
                          SelectedItem="{Binding EditInvestment}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource MaterialDesignComboBox}" Margin="0 0 0 8"/>

                <ComboBox materialDesign:HintAssist.Hint="Activity"
                          ItemsSource="{Binding ActivityTypes}"
                          SelectedItem="{Binding EditActivity}"
                          Style="{StaticResource MaterialDesignComboBox}" Margin="0 0 0 8"/>

                <TextBox materialDesign:HintAssist.Hint="Quantity"
                         Text="{Binding EditQuantity}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0 0 0 8"/>

                <TextBox materialDesign:HintAssist.Hint="Price"
                         Text="{Binding EditPrice}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0 0 0 8"/>

                <TextBox materialDesign:HintAssist.Hint="Total"
                         Text="{Binding EditTotal}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0 0 0 8"/>

                <TextBox materialDesign:HintAssist.Hint="Memo"
                         Text="{Binding EditMemo}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0 0 0 12"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Save"   Command="{Binding SaveCommand}"   Style="{StaticResource MaterialDesignRaisedButton}" Margin="0 0 8 0"/>
                    <Button Content="Cancel" Command="{Binding CancelEditCommand}" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </StackPanel>

                <Separator Margin="0 12"/>
                <TextBlock Text="Update Investment Price" Style="{StaticResource MaterialDesignCaptionTextBlock}" Margin="0 0 0 8"/>
                <Button Content="Save Price for Today" Command="{Binding UpdatePriceCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
