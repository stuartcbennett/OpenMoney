<UserControl x:Class="OpenMoney.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded">

    <TabControl Style="{StaticResource MaterialDesignTabControl}" Margin="8">

        <!-- ── Accounts ── -->
        <TabItem Header="Accounts">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Scrollable list -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0 0 0 12">
                    <ListBox ItemsSource="{Binding Accounts}"
                             SelectedItem="{Binding SelectedAccount}"
                             DisplayMemberPath="Name"/>
                </ScrollViewer>

                <!-- Edit form -->
                <StackPanel Grid.Row="1">
                    <TextBox materialDesign:HintAssist.Hint="Name"
                             Text="{Binding AccountName}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0 0 0 8"/>
                    <TextBox materialDesign:HintAssist.Hint="Institution"
                             Text="{Binding AccountInstitution}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0 0 0 12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save"   Command="{Binding SaveAccountCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" Margin="0 0 8 0"/>
                        <Button Content="Delete" Command="{Binding DeleteAccountCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- ── Investments ── -->
        <TabItem Header="Investments">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Scrollable list -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0 0 0 12">
                    <ListBox ItemsSource="{Binding Investments}"
                             SelectedItem="{Binding SelectedInvestment}"
                             DisplayMemberPath="Name"/>
                </ScrollViewer>

                <!-- Edit form -->
                <StackPanel Grid.Row="1">
                    <TextBox materialDesign:HintAssist.Hint="Name"
                             Text="{Binding InvestmentName}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0 0 0 8"/>
                    <TextBox materialDesign:HintAssist.Hint="Ticker (optional)"
                             Text="{Binding InvestmentTicker}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0 0 0 8"/>
                    <ComboBox materialDesign:HintAssist.Hint="Type"
                              ItemsSource="{Binding InvestmentTypes}"
                              SelectedItem="{Binding InvestmentType}"
                              Style="{StaticResource MaterialDesignComboBox}" Margin="0 0 0 8"/>
                    <TextBox materialDesign:HintAssist.Hint="Initial Price"
                             Text="{Binding InvestmentInitialPrice}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0 0 0 12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save"   Command="{Binding SaveInvestmentCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" Margin="0 0 8 0"/>
                        <Button Content="Delete" Command="{Binding DeleteInvestmentCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- ── Import Transactions ── -->
        <TabItem Header="Import Transactions">
            <StackPanel Margin="16">
                <TextBlock Text="Select a transaction file to import."
                           Style="{StaticResource MaterialDesignBody1TextBlock}" Margin="0 0 0 16"/>

                <Grid Margin="0 0 0 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             materialDesign:HintAssist.Hint="File path"
                             Text="{Binding ImportFilePath}"
                             IsReadOnly="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0 0 8 0"/>
                    <Button Grid.Column="1"
                            Content="Browse…"
                            Command="{Binding BrowseFileCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            VerticalAlignment="Center"/>
                </Grid>

                <Button Content="Import" Command="{Binding ImportTransactionsCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Left" Margin="0 0 0 12"/>

                <TextBlock Text="{Binding ImportStatus}"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </TabItem>

    </TabControl>
</UserControl>
