<UserControl x:Class="OpenMoney.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:oxy="http://oxyplot.org/wpf"
             Loaded="UserControl_Loaded">
    <ScrollViewer>
        <StackPanel Margin="16">

            <!-- Net Worth -->
            <TextBlock Text="Net Worth Over Time" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 8"/>
            <oxy:PlotView Model="{Binding NetWorthModel}" Height="220" Margin="0 0 0 24"/>

            <!-- Account Value -->
            <TextBlock Text="Account Value Over Time" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 8"/>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                <ComboBox ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource MaterialDesignComboBox}" Width="220"/>
                <Button Content="Load" Command="{Binding LoadAccountChartCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="8 0 0 0"/>
            </StackPanel>
            <oxy:PlotView Model="{Binding AccountModel}" Height="220" Margin="0 0 0 24"/>

            <!-- Price History -->
            <TextBlock Text="Investment Price History" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0 0 0 8"/>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                <ComboBox ItemsSource="{Binding Investments}"
                          SelectedItem="{Binding SelectedInvestment}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource MaterialDesignComboBox}" Width="220"/>
                <Button Content="Load" Command="{Binding LoadPriceChartCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="8 0 0 0"/>
            </StackPanel>
            <oxy:PlotView Model="{Binding PriceModel}" Height="220"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
